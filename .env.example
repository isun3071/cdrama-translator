# Translation (hot path) — stays on Groq for lowest TTFT.
GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=qwen/qwen3.6-27b            # translator model (Qwen is best on Chinese)

# Offline JUDGE / grader (audit.py --judge, drift_judge.py, persona_ab.py). Judging is
# a batch pass, so quality beats speed — use a strong grader with good CHINESE (MQM
# adequacy means reading the source). llama is a fine fluency judge but weak on hanzi;
# via OpenRouter you can pick DeepSeek / Claude / GPT-class instead.
# JUDGE_PROVIDER=groq                     # groq (default) | openrouter
# JUDGE_MODEL=                            # groq: llama-3.3-70b-versatile ; openrouter: deepseek/deepseek-chat
# OPENROUTER_API_KEY=                     # required when JUDGE_PROVIDER=openrouter
# GROQ_JUDGE_VOTES=3                      # votes to aggregate (temp auto-bumps >0 when >1 so they vary)
# GROQ_DRIFT_MODEL=                       # optional: override just the drift judge's model
