# ── Translation (hot path) — stays on Groq for lowest TTFT ──
GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=qwen/qwen3.6-27b

# ── Offline JUDGE / grader (audit.py --judge, drift_judge.py, persona_ab.py) ──
# It's a batch pass, so quality beats speed: use a strong grader with good CHINESE
# (MQM adequacy means reading the source). Do NOT use Qwen — same family as the
# translator, so 10-25% self-preference bias. Each run prints its cost; a 40-line
# x 3-vote audit is ~2 cents on DeepSeek. Comments live on their OWN lines below,
# never after a value — an inline comment gets swallowed into the value when you
# uncomment it.
#
# Provider: groq (default) or openrouter
# JUDGE_PROVIDER=openrouter
# OpenRouter key (needed when JUDGE_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-your-key-here
#
# Single grader — cheap, strong Chinese, not Qwen-family:
# JUDGE_MODEL=deepseek/deepseek-chat
#
# ...or a diverse PANEL, one vote each (diversity bounds judge bias; overrides votes):
# JUDGE_MODELS=deepseek/deepseek-chat,google/gemini-2.5-flash,anthropic/claude-sonnet-4
#
# Single-model votes to aggregate (temp auto-bumps >0 when >1; ignored if JUDGE_MODELS set)
# GROQ_JUDGE_VOTES=3
