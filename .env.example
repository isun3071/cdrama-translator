# ── Translation (hot path) — stays on Groq for lowest TTFT ──
GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=qwen/qwen3.6-27b

# ── Offline JUDGE / grader + TEACHER (audit.py --judge, drift_judge.py, persona_ab.py, track.py) ──
# Batch passes, so quality beats speed: use a strong model with good CHINESE (MQM
# adequacy / faithful translation means reading the source). Do NOT judge with Qwen —
# same family as the translator, so 10-25% self-preference bias. Each run prints cost.
# Comments live on their OWN lines below, never after a value — an inline comment gets
# swallowed into the value when you uncomment it.
#
# Provider: groq (default) or openrouter
# JUDGE_PROVIDER=openrouter
# OpenRouter key (needed when JUDGE_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-your-key-here
#
# Grader model — cheap, strong Chinese, not Qwen-family:
# JUDGE_MODEL=deepseek/deepseek-chat
#
# Teacher model for track.py (falls back to JUDGE_MODEL):
# TEACHER_MODEL=deepseek/deepseek-chat
#
# ...or a diverse grader PANEL, one vote each (diversity bounds judge bias):
# JUDGE_MODELS=deepseek/deepseek-chat,google/gemini-2.5-flash,anthropic/claude-sonnet-4
#
# Reasoning is OFF by default (it wastes tokens and reasoning models can return null
# content). Set on, or a level (low|medium|high), only if you want it:
# JUDGE_REASONING=off
#
# Single-model votes to aggregate (temp auto-bumps >0 when >1; ignored if JUDGE_MODELS set)
# GROQ_JUDGE_VOTES=3
