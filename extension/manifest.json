{
  "manifest_version": 2,
  "name": "CDrama Subtitle Detector (dev)",
  "version": "0.3.0",
  "description": "Sessions 1-3: capture + change detection, POST 3 frames to the local sidecar, overlay the translation. Debug view included.",
  "permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "browser_action": {
    "default_title": "Toggle subtitle detector"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/util.js",
        "content/capture.js",
        "content/detector.js",
        "content/service.js",
        "content/overlay.js",
        "content/panel.js",
        "content/main.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cdrama-subtitle-detector-dev@local"
    }
  }
}
